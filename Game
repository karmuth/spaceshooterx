package game;

import java.awt.*;
import java.awt.event.*;

/**
 * This class provides the framework that is extended by the space shooter game.
 * It creates a window with a drawing canvas that is constantly updated using buffering.
 * Every subclass must implement the paint method to define how each frame is drawn.
 */
abstract class Game extends Canvas {

    protected boolean on = true;
    protected int width, height;
    protected Image buffer;

    /**
     * Constructs a game window with specific title, width, and height.
     * Initializes the canvas and sets up 
     * the window size, visibility, and closing behavior.
     * @param name the title of the game window
     * @param inWidth the width of the window in pixels
     * @param inHeight the height of the window in pixels
     */
    public Game(String name, int inWidth, int inHeight) {
        width = inWidth;
        height = inHeight;

        Frame frame = new Frame(name);
        frame.add(this);
        frame.setSize(width, height);
        frame.setVisible(true);
        frame.setResizable(false);
        frame.addWindowListener(new WindowAdapter() {
            /**
             * Reacts to the window closing event by terminating the program.
             *
             * @param e the window event
             */
            public void windowClosing(WindowEvent e) {
                System.exit(0);
            }
        });

        buffer = createImage(width, height);
    }

    /**
     * Draws a single frame that is called throughout the game.
     * This method is must be implemented by the subclass of Game.
     *
     * @param brush the Graphics object used for rendering
     */
    abstract public void paint(Graphics brush);

    /**
     * Updates the display by drawing a buffer and then rendering 
     * the buffer to the screen. This is used to prevent flickering.
     *
     * @param brush the Graphics object used for rendering to the screen
     */
    public void update(Graphics brush) {
        paint(buffer.getGraphics());
        brush.drawImage(buffer, 0, 0, this);

        if (on) {
            sleep(10);
            repaint();
        }
    }

    /**
     * Pauses execution for a specified duration.
     *
     * @param time the number of milliseconds to sleep
     */
    private void sleep(int time) {
        try {
            Thread.sleep(time);
        } catch (Exception exc) {
        	
        }
    }
}
