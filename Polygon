package game;

/**
 * This class represents a polygon with a shape, position, and rotation.
 * The polygon stores its base shape as a list of points and can return
 * transformed points based on its current position and rotation.
 */
class Polygon {
    private Point[] shape;
    public Point position;
    public double rotation;

    /**
     * This method constructs a polygon with the specified shape, position, and rotation.
     *
     * @param inShape the points defining the polygon's shape
     * @param inPosition the initial position offset
     * @param inRotation the initial rotation in degrees
     */
    public Polygon(Point[] inShape, Point inPosition, double inRotation) {
        shape = inShape;
        position = inPosition;
        rotation = inRotation;

        Point origin = shape[0].clone();
        for (Point p : shape) {
            if (p.x < origin.x) origin.x = p.x;
            if (p.y < origin.y) origin.y = p.y;
        }

        for (Point p : shape) {
            p.x -= origin.x;
            p.y -= origin.y;
        }
    }

    /**
     * Returns the transformed points of the polygon after applying its
     * current position and rotation.
     *
     * @return an array of transformed points
     */
    public Point[] getPoints() {
        Point center = findCenter();
        Point[] points = new Point[shape.length];

        for (int i = 0; i < shape.length; i++) {
            Point p = shape[i];
            double x = ((p.x - center.x) * Math.cos(Math.toRadians(rotation)))
                     - ((p.y - center.y) * Math.sin(Math.toRadians(rotation)))
                     + center.x + position.x;
            double y = ((p.x - center.x) * Math.sin(Math.toRadians(rotation)))
                     + ((p.y - center.y) * Math.cos(Math.toRadians(rotation)))
                     + center.y + position.y;
            points[i] = new Point(x, y);
        }

        return points;
    }

    /**
     * This method determines whether the parameter point lies inside the polygon.
     *
     * @param point the point to test
     * @return true if the point is inside the polygon, false otherwise
     */
    public boolean contains(Point point) {
        Point[] points = getPoints();
        double crossingNumber = 0;

        for (int i = 0, j = 1; i < shape.length; i++, j = (j + 1) % shape.length) {
            if ((((points[i].x < point.x) && (point.x <= points[j].x)) ||
                 ((points[j].x < point.x) && (point.x <= points[i].x))) &&
                (point.y > points[i].y + (points[j].y - points[i].y) /
                 (points[j].x - points[i].x) * (point.x - points[i].x))) {
                crossingNumber++;
            }
        }

        return crossingNumber % 2 == 1;
    }

    /**
     * Determines whether a polygon collides with another polygon.
     *
     * @param other the other polygon that is tested against
     * @return true if the polygons intersect, false otherwise
     */
    public boolean collides(Polygon other) {
        Point[] a = this.getPoints();
        Point[] b = other.getPoints();

        for (int i = 0; i < a.length; i++) {
            if (other.contains(a[i])) {
                return true;
            }
        }

        for (int i = 0; i < b.length; i++) {
            if (this.contains(b[i])) {
                return true;
            }
        }

        return false;
    }
    /**
     * Rotates the polygon by the specified number of degrees.
     *
     * @param degrees the amount of rotation in degrees
     */
    public void rotate(int degrees) {
        rotation = (rotation + degrees) % 360;
    }

    /**
     * Computes the area of the polygon.
     *
     * @return the area of the polygon
     */
    private double findArea() {
        double sum = 0;
        for (int i = 0, j = 1; i < shape.length; i++, j = (j + 1) % shape.length) {
            sum += shape[i].x * shape[j].y - shape[j].x * shape[i].y;
        }
        return Math.abs(sum / 2);
    }

    /**
     * Computes the center point of the polygon.
     *
     * @return the center of the polygon
     */
    private Point findCenter() {
        Point sum = new Point(0, 0);

        for (int i = 0, j = 1; i < shape.length; i++, j = (j + 1) % shape.length) {
            sum.x += (shape[i].x + shape[j].x)
                   * (shape[i].x * shape[j].y - shape[j].x * shape[i].y);
            sum.y += (shape[i].y + shape[j].y)
                   * (shape[i].x * shape[j].y - shape[j].x * shape[i].y);
        }

        double area = findArea();
        return new Point(Math.abs(sum.x / (6 * area)), Math.abs(sum.y / (6 * area)));
    }
}
