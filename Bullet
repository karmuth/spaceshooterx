package game;

import java.awt.*;

class Bullet extends Polygon {
    private boolean active;
    private int life;

    public Bullet(Point[] shape, Point position, double rotation) {
        super(shape, position, rotation);
        active = true;
        life = 80;
    }

    public void move() {
        double speed = 10.0;
        position.x += speed * Math.cos(Math.toRadians(rotation));
        position.y += speed * Math.sin(Math.toRadians(rotation));
        life--;

        if (life <= 0) {
            active = false;
        }
    }

    public void wrap(int width, int height) {
        if (position.x < 0) {
            position.x = width;
        }
        if (position.x > width) {
            position.x = 0;
        }
        if (position.y < 0) {
            position.y = height;
        }
        if (position.y > height) {
            position.y = 0;
        }
    }

    public void paint(Graphics brush) {
        if (!active) {
            return;
        }

        Point[] points = getPoints();
        int[] xPoints = new int[points.length];
        int[] yPoints = new int[points.length];

        for (int i = 0; i < points.length; i++) {
            xPoints[i] = (int) points[i].x;
            yPoints[i] = (int) points[i].y;
        }

        brush.setColor(Color.white);
        brush.fillPolygon(xPoints, yPoints, points.length);
    }

    public boolean isActive() {
        return active;
    }

    public void deactivate() {
        active = false;
    }
}
