package game;

import java.awt.*;

/**
 * This method represents the projectile fired by the ship.
 * A bullet moves in the direction it was fired, and continues along its path
 * until it reaches the end of the screen or collides with the asteroid.
 */
class Bullet extends Polygon implements Movable {
    private boolean active;

    /**
     * Constructs a bullet with the provided parameters for shape, position, and rotation.
     *
     * @param shape the polygon points that the bullet shape is composed of
     * @param position the starting position of the bullet
     * @param rotation the direction of travel in degrees
     */
    public Bullet(Point[] shape, Point position, double rotation) {
        super(shape, position, rotation);
        active = true;
    }

    /**
     * Moves the bullet forward in the direction of its rotation.
     * The bullet stops when it leaves the game window.
     */
    public void move() {
        double speed = 10.0;
        position.x += speed * Math.cos(Math.toRadians(rotation));
        position.y += speed * Math.sin(Math.toRadians(rotation));

        if (position.x < 0 || position.x > 800 || position.y < 0 || position.y > 600) {
            active = false;
        }
    }

    /**
     * Determines whether the bullet is active.
     *
     * @return true if the bullet is active, false otherwise
     */
    public boolean isActive() {
        return active;
    }

    /**
     * This method makes the bullet inactive.
     */
    public void deactivate() {
        active = false;
    }

    /**
     * If active is true, the bullet is displayed on the screen.
     *
     * @param brush the Graphics object that is used for drawing
     */
    public void paint(Graphics brush) {
        if (active == false) {
            return;
        }

        Point[] points = getPoints();
        int[] x = new int[points.length];
        int[] y = new int[points.length];

        for (int i = 0; i < points.length; i++) {
            x[i] = (int) points[i].x;
            y[i] = (int) points[i].y;
        }

        brush.setColor(Color.white);
        brush.fillPolygon(x, y, points.length);
    }
}
