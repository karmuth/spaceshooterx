package game;

import java.awt.*;

/**
 * Represents a falling asteroid in the game.
 * The asteroid moves downward, can take multiple hits, and is destroyed
 * when its health reaches zero.
 */
class Asteroid extends Polygon implements Movable {

    private double fallSpeed;
    private int hitsRemaining;

    /**
     * Constructs an asteroid with the specified shape, position, rotation,
     * fall speed, and durability.
     *
     * @param shape the polygon points defining the asteroid shape
     * @param position the starting position of the asteroid
     * @param rotation the initial rotation angle in degrees
     * @param fallSpeed the asteroid's movement speed
     * @param hitsRemaining the number of hits required to destroy the asteroid
     */
    public Asteroid(Point[] shape, Point position, double rotation, double fallSpeed, int hitsRemaining) {
        super(shape, position, rotation);
        this.fallSpeed = fallSpeed;
        this.hitsRemaining = hitsRemaining;
    }

    /**
     * Moves the asteroid downward based on its current fall speed.
     */
    public void move() {
        position.y += fallSpeed;
    }

    /**
     * Determines whether the asteroid has reached the ground.
     *
     * @param groundY the y-coordinate of the ground
     * @return true if the asteroid has reached the ground, otherwise returns false
     */
    public boolean hitGround(int groundY) {
        return position.y >= groundY - 30;
    }

    /**
     * Reduces the asteroid's health by one hit.
     */
    public void takeHit() {
        hitsRemaining--;
    }

    /**
     * Checks whether the asteroid has been destroyed.
     *
     * @return true if the asteroid has no remaining health, false otherwise
     */
    public boolean isDestroyed() {
        return hitsRemaining <= 0;
    }

    /**
     * Returns the number of hits remaining before the asteroid is destroyed.
     *
     * @return the remaining hit count
     */
    public int getHitsRemaining() {
        return hitsRemaining;
    }

    /**
     * Draws the asteroid on the screen using its current transformed points.
     *
     * @param brush the Graphics object used for drawing
     */
    public void paint(Graphics brush) {
        Point[] points = getPoints();
        int[] x = new int[points.length];
        int[] y = new int[points.length];

        for (int i = 0; i < points.length; i++) {
            x[i] = (int) points[i].x;
            y[i] = (int) points[i].y;
        }

        brush.setColor(Color.white);
        brush.drawPolygon(x, y, points.length);
    }
}
